{
  "name": "forge",
  "version": "0.4.0",
  "description": "Agentic coding workflow control plane — CLI + Claude Code plugin",
  "license": "MIT",
  "author": "Tripp Cashel",
  "homepage": "https://github.com/tcashel/forge#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tcashel/forge.git"
  },
  "bugs": "https://github.com/tcashel/forge/issues",
  "type": "module",
  "keywords": [
    "claude-code-plugin",
    "agentic-coding",
    "tmux",
    "git-worktree"
  ],
  "engines": {
    "bun": ">=1.3"
  },
  "bin": {
    "forge": "./bin/forge.ts"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "prepublishOnly": "echo 'Registry publishing is not supported yet: the root skills/ symlink is not packaged into npm tarballs, so reviewer/critic/fixer/planner prompts would ship empty. Install via git (see README). See CONTRIBUTING.md > Packaging.' && exit 1"
  },
  "dependencies": {
    "@git-diff-view/file": "^0.1.6",
    "@git-diff-view/react": "^0.1.6",
    "@git-diff-view/shiki": "^0.1.6",
    "@preact/signals": "^2.9.2",
    "markdown-it": "^14.2.0",
    "markdown-it-task-lists": "^2.1.1",
    "mermaid": "^11.15.0",
    "preact": "^10.24.0",
    "shiki": "^4.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@happy-dom/global-registrator": "^20.10.6",
    "@types/bun": "^1.3.14",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.0.0",
    "playwright": "^1.61.0",
    "typescript": "^6.0.3"
  }
}
