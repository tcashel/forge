{
  "name": "forge",
  "version": "0.3.0",
  "description": "Mission control for agentic coding workflows — spec, launch, track, review, PR",
  "private": true,
  "type": "module",
  "keywords": [
    "pi-package"
  ],
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "test": "node --test --experimental-strip-types tests/*.test.ts",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome check --write ."
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@mariozechner/pi-coding-agent": "^0.70.6",
    "@mariozechner/pi-tui": "^0.70.6"
  }
}
